# Maintainer: Maksim Bondarenkov <maksapple2306@gmail.com>

_realname=rusty-autoclicker-git
pkgbase=mingw-w64-${_realname}
pkgname=${MINGW_PACKAGE_PREFIX}-${_realname}
pkgver=v2.4.0.r9.g806ca4e
pkgrel=1
pkgdesc="A pure Rust portable auto clicker built for Linux, macOS & Windows (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64' 'clang64' 'clangarm64')
url="https://github.com/MrTanoshii/rusty-autoclicker"
license=('spdx:CC0')
makedepends=("${MINGW_PACKAGE_PREFIX}-rust" 'git')
provides=("${pkgname%-git}")
conflicts=("${pkgname%-git}")
options=('!strip')
source=('git+https://github.com/MrTanoshii/rusty-autoclicker.git')
sha256sums=('SKIP')

pkgver() {
	cd "${_realname%-git}"
  git describe --long --tags --abbrev=7 | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd "${_realname%-git}"

  cargo fetch --locked --target "${RUST_CHOST}"
}

build() {
	cd "${_realname%-git}"

  cargo build --frozen --release
}

package() {
	cd "${_realname%-git}"

  install -Dm755 target/release/${_realname%-git} "${pkgdir}${MINGW_PREFIX}/bin/${_realname%-git}"
}
